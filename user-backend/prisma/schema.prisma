// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  User
  Police
  Medic
  FireFigther
  Traffic
}

model User {
  userId    String   @id @default(uuid())
  firstname String
  lastname  String
  email     String   @unique
  phone     String?
  password  String
  location  String?
  role      Role     @default(User)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  alertsCreated   Alerts[] @relation("UserAlerts")
  alertsResponded Alerts[] @relation("RespondentAlerts")
}

model RefreshToken {
  id           String   @id @default(uuid())
  hashedToken  String   @unique
  userId       String    
  user         User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  // Security & Metadata
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}


model Alerts {
  id            String @id @default(uuid())
  userId        String
  user          User   @relation("UserAlerts", fields: [userId], references: [userId])
  respondentId  String
  respondent    User   @relation("RespondentAlerts", fields: [respondentId], references: [userId])
  latitude      Float
  longitude     Float
}